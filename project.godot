;
; TiltMerge — Godot 4.x project file
; Genre: fast physics-merge puzzle for Android
;

config_version=5

[application]

config/name="TiltMerge"
config/description="Быстрая головоломка: наклоняй телефон, чтобы одинаковые кубики слипались."
run/main_scene="res://scenes/Boot.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/graphics/icon.png"
config/version="1.0.6"
# Без этого Android Back / свайп-назад сразу закрывает приложение,
# и наш BackHandler не успевает перевести на предыдущий экран.
config/quit_on_go_back=false

[autoload]

I18n="*res://scripts/I18n.gd"
GameConfig="*res://scripts/GameConfig.gd"
MergeBus="*res://scripts/MergeBus.gd"
SaveSystem="*res://scripts/SaveSystem.gd"
GameManager="*res://scripts/GameManager.gd"
AudioManager="*res://scripts/AudioManager.gd"
Haptics="*res://scripts/Haptics.gd"
Achievements="*res://scripts/Achievements.gd"
SkinsManager="*res://scripts/SkinsManager.gd"
Analytics="*res://scripts/Analytics.gd"
ABTest="*res://scripts/ABTest.gd"
BackHandler="*res://scripts/BackHandler.gd"
UiTheme="*res://scripts/UiTheme.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[input]

tilt_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":65,"key_label":0,"unicode":97,"location":0,"echo":false,"script":null)
]
}
tilt_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":68,"key_label":0,"unicode":100,"location":0,"echo":false,"script":null)
]
}
ui_pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194305,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[input_devices]

sensors/enable_accelerometer=true
sensors/enable_gravity=true
sensors/enabled=true

[internationalization]

locale/translations=PackedStringArray("res://translations/ar.ar.translation", "res://translations/cs.cs.translation", "res://translations/de.de.translation", "res://translations/en.en.translation", "res://translations/es.es.translation", "res://translations/fr.fr.translation", "res://translations/hi.hi.translation", "res://translations/id.id.translation", "res://translations/it.it.translation", "res://translations/ja.ja.translation", "res://translations/ko.ko.translation", "res://translations/nl.nl.translation", "res://translations/pl.pl.translation", "res://translations/pt.pt.translation", "res://translations/pt_BR.pt_BR.translation", "res://translations/ru.ru.translation", "res://translations/sv.sv.translation", "res://translations/th.th.translation", "res://translations/tr.tr.translation", "res://translations/uk.uk.translation", "res://translations/vi.vi.translation", "res://translations/zh_CN.zh_CN.translation", "res://translations/zh_TW.zh_TW.translation")
locale/translation_remaps={}
locale/fallback="en"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0.07, 0.08, 0.12, 1)
