{
  "_comment": "TiltMerge — главный data-driven конфиг баланса. Код читает отсюда, не хардкодит. Объяснения — в docs/BALANCE.md",
  "_version": 1,

  "game": {
    "viewport": { "width": 720, "height": 1280 },
    "gravity": { "x": 0, "y": 980 },
    "game_over_line_y": 80,
    "game_over_grace_sec": 1.5
  },

  "cube": {
    "base_radius": 28,
    "size_multiplier": 1.3,
    "physics": {
      "bounce": 0.3,
      "friction": 0.6,
      "mass_base": 1.0
    },
    "palette": {
      "1": "#E63946",
      "2": "#F4A261",
      "3": "#E9C46A",
      "4": "#2A9D8F",
      "5": "#264653",
      "6": "#8338EC",
      "7": "#6A4C2A",
      "8": "#F1FAEE",
      "9": "#1D2225",
      "10": "#FF00FF",
      "11": "#00E5FF",
      "12": "#FFD700"
    },
    "tiers": [
      { "tier": 1,  "name": "Cherry",   "score": 2 },
      { "tier": 2,  "name": "Tangerine","score": 4 },
      { "tier": 3,  "name": "Lemon",    "score": 8 },
      { "tier": 4,  "name": "Lime",     "score": 16 },
      { "tier": 5,  "name": "Sky",      "score": 32 },
      { "tier": 6,  "name": "Grape",    "score": 64 },
      { "tier": 7,  "name": "Chestnut", "score": 128 },
      { "tier": 8,  "name": "Pearl",    "score": 256 },
      { "tier": 9,  "name": "Onyx",     "score": 512 },
      { "tier": 10, "name": "Prism",    "score": 1024 },
      { "tier": 11, "name": "Crystal",  "score": 2048 },
      { "tier": 12, "name": "Nova",     "score": 4096 }
    ]
  },

  "merge": {
    "max_tier": 12,
    "super_bonus_multiplier": 3.0
  },

  "spawn": {
    "interval_base_sec": 1.5,
    "interval_min_sec": 0.55,
    "interval_score_divisor": 5000,
    "score_tiers": [
      { "min_score": 0,    "tiers": [1],         "weights": [100] },
      { "min_score": 50,   "tiers": [1, 2],      "weights": [70, 30] },
      { "min_score": 200,  "tiers": [1, 2, 3],   "weights": [55, 30, 15] },
      { "min_score": 600,  "tiers": [1, 2, 3, 4],"weights": [45, 28, 18, 9] },
      { "min_score": 1500, "tiers": [1, 2, 3, 4, 5], "weights": [38, 25, 18, 12, 7] }
    ]
  },

  "tilt": {
    "sensitivity": 1.0,
    "max_force": 1500,
    "deadzone": 0.05,
    "fallback_swipe": true
  },

  "combo": {
    "window_sec": 2.0,
    "multipliers": [1.0, 1.0, 1.5, 2.0, 3.0, 5.0]
  },

  "modes": {
    "classic": { "spawn_interval_mult": 1.0, "game_over": true,  "duration_sec": null },
    "blitz":   { "spawn_interval_mult": 0.8, "game_over": true,  "duration_sec": 60 },
    "zen":     { "spawn_interval_mult": 1.3, "game_over": false, "duration_sec": null },
    "daily":   { "spawn_interval_mult": 1.0, "game_over": true,  "duration_sec": null, "seeded": true }
  },

  "ads": {
    "interstitial": { "every_n_restarts": 3, "min_interval_sec": 120 },
    "revive_per_run": 1
  },

  "iap": {
    "remove_ads_price_usd": 1.99,
    "skin_price_usd_range": [0.99, 1.99]
  },

  "achievements": [
    { "id": "ach_first_merge", "name": "First Touch",     "condition": "merges >= 1" },
    { "id": "ach_combo_5",     "name": "On Fire",         "condition": "combo >= 5" },
    { "id": "ach_tier_7",      "name": "Big One",         "condition": "max_tier >= 7" },
    { "id": "ach_tier_12",     "name": "Nova",            "condition": "max_tier >= 12" },
    { "id": "ach_score_1k",    "name": "1K Club",         "condition": "score >= 1000" },
    { "id": "ach_score_10k",   "name": "10K Club",        "condition": "score >= 10000" },
    { "id": "ach_10_games",    "name": "Regular",         "condition": "games >= 10" },
    { "id": "ach_revive_5",    "name": "Second Chance",   "condition": "revives >= 5" },
    { "id": "ach_no_tilt",     "name": "Purist",          "condition": "score_swipe >= 5000" }
  ],

  "daily": {
    "leaderboard_id": "daily_challenge",
    "seed_formula": "hash(YYYY-MM-DD)"
  }
}
